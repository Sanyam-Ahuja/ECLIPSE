# ===== CampuGrid Environment Variables =====

# PostgreSQL
POSTGRES_USER=campugrid
POSTGRES_PASSWORD=campugrid_dev_password
POSTGRES_DB=campugrid
DATABASE_URL=postgresql+asyncpg://campugrid:campugrid_dev_password@localhost:5432/campugrid

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=campugrid
MINIO_SECRET_KEY=campugrid_dev_secret
MINIO_SECURE=false

# JWT Auth
