# ===== CampuGrid Environment Variables =====

# PostgreSQL
POSTGRES_USER=campugrid
POSTGRES_PASSWORD=campugrid_dev_password
POSTGRES_DB=campugrid
DATABASE_URL=postgresql+asyncpg://campugrid:campugrid_dev_password@localhost:5432/campugrid

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=campugrid
MINIO_SECRET_KEY=campugrid_dev_secret
MINIO_SECURE=false

# JWT Auth
JWT_SECRET_KEY=dev-secret-key-change-in-production-please
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Gemini API (for Docker config verification/generation)
GEMINI_API_KEY=your-gemini-api-key

# Sentry (optional)
SENTRY_DSN=

# Grafana
GRAFANA_PASSWORD=campugrid_grafana

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ORIGINS=["http://localhost:3000"]
